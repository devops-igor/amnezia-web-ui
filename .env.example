# Amnezia Web Panel — Environment Variables
#
# Copy this file to .env and fill in all values:
#   cp .env.example .env
#
# Generate a secure SECRET_KEY:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

# =============================================================================
# REQUIRED
# =============================================================================

# Secret key for session cookies and cryptographic operations.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<generate-with-command-above>

# =============================================================================
# APPLICATION
# =============================================================================

# Docker image tag for the Amnezia panel. Defaults to latest stable.
# For production, pin to a specific version tag or SHA.
AMNEZIA_IMAGE=ghcr.io/devops-igor/amnezia-web-ui:latest

# Port for direct panel access (bypasses BunkerWeb).
# When using BunkerWeb profile, set APP_PORT= (empty) so the panel
# is only accessible through BunkerWeb. Note: Docker Compose treats
# an empty APP_PORT as a random ephemeral host port, not "no port".
# The panel will still be reachable on that random port from the host.
# For true isolation, rely on BunkerWeb as the sole entry point.
APP_PORT=5000

# Directory on the host for persistent panel data ( SQLite DB, etc. )
DATA_DIR=./data

# =============================================================================
# TRUSTED PROXIES
# =============================================================================

# Comma-separated list of trusted proxy IPs/CIDRs for X-Forwarded-For validation.
# Supports CIDR notation (e.g. 172.18.0.0/24) for Docker networks and plain IPs.
# The panel extracts the real client IP from these sources.
# Defaults to the bw-net Docker subnet.
TRUSTED_PROXIES=172.18.0.0/24

# =============================================================================
# BUNKERWEB WAF
# Activated with: docker compose --profile bunkerweb up -d
# =============================================================================

# Legacy — prefer PANEL_DOMAIN + BUNKERWEB_UI_DOMAIN for multisite.
# Used as default for PANEL_DOMAIN (see BUNKERWEB MULTISITE section below).
# For a single domain:   SERVER_NAME=vpn.example.com
# For multiple domains:  SERVER_NAME=vpn.example.com panel.example.com
SERVER_NAME=localhost

# Enable Let's Encrypt automatic certificate generation.
# Set to "no" if using external certificates or a wildcard cert.
AUTO_LETS_ENCRYPT=yes

# Email address for Let's Encrypt certificate notifications.
EMAIL_LETS_ENCRYPT=admin@example.com

# BunkerWeb version tag.
BUNKERWEB_VERSION=1.6.9

# Enable BunkerWeb web UI (available on port 8080/8443 alongside main ports).
USE_UI=yes

# Enable Gzip compression for HTTP responses.
USE_GZIP=yes

# Enable ModSecurity Web Application Firewall rules.
USE_MODSECURITY=yes

# Enable CrowdSec integration (requires additional CrowdSec setup).
USE_CROWDSEC=no

# Allowed HTTP methods through ModSecurity WAF.
# The panel's speed-limit API requires PATCH; DELETE is included for future use.
# If you restrict this (e.g. to GET|POST|HEAD only), PATCH requests will return 405.
ALLOWED_METHODS=GET|POST|HEAD|PATCH|DELETE

# Multi-site mode — required for per-site reverse proxy config.
MULTISITE=yes

# =============================================================================
# IP WHITELISTING (applied at BunkerWeb level)
# =============================================================================

# Enable IP-based access restriction for the panel domain.
# Applied per-site via ${PANEL_DOMAIN}_USE_WHITELIST_IP in docker-compose.yml.
# The global BunkerWeb default is "no" — only the panel site overrides it when set to "yes".
# BunkerWeb autoconf does NOT support whitelist settings via Docker labels;
# per-site env vars on the bunkerweb service are the correct mechanism.
USE_WHITELIST_IP=yes

# Space- or comma-separated list of IPs/CIDRs allowed to access the panel.
# Example: 203.0.113.50,10.0.0.0/24
WHITELIST_IP_LIST=203.0.113.50,203.0.113.100

# =============================================================================
# BUNKERWEB ADVANCED SECURITY
# =============================================================================

# Bad behavior detection (blocks known malicious bots).
USE_BAD_BEHAVIOR=yes

# Request rate limiting via ModSecurity.
USE_LIMIT_REQ=yes

# Connection limiting via ModSecurity.
USE_LIMIT_CONN=yes

# =============================================================================
# BUNKERWEB MULTISITE — Domain Routing
# Activated with: docker compose --profile bunkerweb up -d
# =============================================================================

# Domain serving the Amnezia Web Panel (reverse-proxied through BunkerWeb).
# Defaults to SERVER_NAME for backward compatibility with single-domain setups.
# Example: vpn.dev.drochi.games
PANEL_DOMAIN=vpn.example.com

# Domain serving the BunkerWeb Web UI (optional).
# Set this to expose BunkerWeb's admin interface on a separate domain.
# Leave empty for single-domain setups — the UI is still accessible via
# BUNKERWEB_UI_PORT below (default: SSH tunnel to localhost:7080).
# Example: dev.drochi.games
BUNKERWEB_UI_DOMAIN=

# Localhost port for direct BunkerWeb UI access (SSH tunnel).
# Default: 127.0.0.1:7080 — accessible only from localhost for security.
# Access via SSH tunnel: ssh -L 7080:127.0.0.1:7080 user@server
# Set to empty string to disable the port mapping entirely.
BUNKERWEB_UI_PORT=127.0.0.1:7080

# =============================================================================
# MTPROXYL (MTProto Proxy)
# Installed on the host via 'mtproxyl install', not via docker compose.
# The panel communicates with the MTProxyL daemon running on the host.
# =============================================================================

# External port for MTProxyL.
# Default 18443 avoids port conflict with bunkerweb (which binds 443).
# Set to 443 only when running MTProxyL WITHOUT the bunkerweb profile.
TELEMT_PORT=18443

# Host timezone for MTProxyL timestamps.
TZ=UTC

# MTProxyL config directory (used by the panel to know where configs live).
# MTProxyL is installed at /opt/mtproxyl/ — its config is at /opt/mtproxyl/config.toml.
# MTProxyL is installed on the host via 'mtproxyl install', not via docker compose.
# TELEMT_CONFIG_DIR and TELEMT_LOG are no longer used — MTProxyL manages its own config and logs.
